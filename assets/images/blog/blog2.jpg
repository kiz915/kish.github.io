<svg width="800" height="400" viewBox="0 0 800 400" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Background -->
    <rect width="800" height="400" fill="#1e293b" />
    
    <!-- Gradient Overlay -->
    <rect width="800" height="400" fill="url(#gradient)" opacity="0.8" />
    
    <!-- Blog Icon -->
    <circle cx="400" cy="200" r="80" fill="white" opacity="0.1" />
    <text x="400" y="220" text-anchor="middle" fill="white" font-size="60" font-family="Arial" font-weight="bold" opacity="0.3">AWS</text>
    
    <!-- Decorative Lines -->
    <path d="M200 300 L600 300" stroke="white" stroke-width="2" opacity="0.2" stroke-dasharray="10 10" />
    <path d="M250 330 L550 330" stroke="white" stroke-width="2" opacity="0.2" stroke-dasharray="10 10" />
    
    <defs>
        <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#6366f1" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.6" />
        </linearGradient>
    </defs>
</svg>
